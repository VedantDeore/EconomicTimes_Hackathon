# ── AI Providers (at least one required) ──
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
AI_PROVIDER=groq

# ── Backend (FastAPI — full URL or port number) ──
AI_PORT=http://127.0.0.1:8000

# ── Supabase (copy these into et-frontend/.env.local for Next.js) ──
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Frontend ──
NEXT_PUBLIC_USE_LOCAL_ENGINE=false

# Also in et-frontend/.env.local (Form 16, AI mentor proxy, life-events, etc.):
# AI_SERVICE_URL=http://127.0.0.1:8000
